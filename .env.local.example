# Copy this file to .env.local and fill in your real keys.
# .env.local is ignored by git in this workspace.
#
# Minimum setup:
# - GAOTAI_API_KEY / GAOTAI_BASE_URL / GAOTAI_MODEL configure the default route.
# - The API should expose an OpenAI-compatible /chat/completions endpoint.
#
# Keep this file as a template only. Do not put real keys here.

# Default OpenAI-compatible route.
GAOTAI_API_KEY=
GAOTAI_BASE_URL=
GAOTAI_MODEL=
GAOTAI_THINKING=enabled
GAOTAI_REASONING_EFFORT=high
GAOTAI_REWRITE_MODEL=
GAOTAI_REWRITE_THINKING=disabled
GAOTAI_REWRITE_REASONING_EFFORT=low
GAOTAI_SUPPORT_THINKING=enabled
GAOTAI_SUPPORT_REASONING_EFFORT=high
GAOTAI_REVIEW_THINKING=disabled
GAOTAI_REVIEW_REASONING_EFFORT=low

# Workbench behavior.
FULL_DRAFT_JOB_TIMEOUT_SECONDS=360
WORKBENCH_REWRITE_LOCAL_FIRST=0
WORKBENCH_FINAL_REVIEW_AI=0
